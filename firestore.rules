rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function validReservationCreate() {
      return request.resource.data.keys().hasOnly([
        'roomId',
        'roomDocId',
        'userId',
        'responsavelNome',
        'status',
        'data',
        'horaInicio',
        'horaFim',
        'createdAt',
        'email'
      ]) &&
      request.resource.data.roomId is string &&
      request.resource.data.roomDocId is string &&
      request.resource.data.userId == request.auth.uid &&
      request.resource.data.responsavelNome is string &&
      request.resource.data.status in ['pendente', 'aprovado'] &&
      request.resource.data.data is timestamp &&
      request.resource.data.horaInicio is timestamp &&
      request.resource.data.horaFim is timestamp &&
      request.resource.data.horaInicio < request.resource.data.horaFim &&
      request.resource.data.createdAt == request.time &&
      request.resource.data.email == request.auth.token.email;
    }

    function validReservationLockCreate() {
      return request.resource.data.keys().hasOnly([
        'reservationId',
        'roomDocId',
        'userId',
        'data',
        'horaInicio',
        'horaFim',
        'status',
        'active',
        'createdAt'
      ]) &&
      request.resource.data.reservationId is string &&
      request.resource.data.roomDocId is string &&
      request.resource.data.userId == request.auth.uid &&
      request.resource.data.data is timestamp &&
      request.resource.data.horaInicio is timestamp &&
      request.resource.data.horaFim is timestamp &&
      request.resource.data.horaInicio < request.resource.data.horaFim &&
      request.resource.data.status in ['pendente', 'aprovado'] &&
      request.resource.data.active == true &&
      request.resource.data.createdAt == request.time;
    }

    // Reservations: only authenticated users can create/read;
    // updates allowed to the reservation owner or admin; deletes only by admin.
    match /reservations/{reservationId} {
      allow read: if signedIn();
      allow create: if signedIn() && validReservationCreate();
      allow update: if signedIn() && (
        isAdmin() ||
        (
          request.auth.uid == resource.data.userId &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.roomDocId == resource.data.roomDocId &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.horaInicio == resource.data.horaInicio &&
          request.resource.data.horaFim == resource.data.horaFim &&
          request.resource.data.responsavelNome == resource.data.responsavelNome &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.status == 'cancelado'
        )
      );
      allow delete: if isAdmin();
    }

    // Reservation locks prevent double booking by reserving 30-minute room slots.
    match /reservationLocks/{lockId} {
      allow read: if signedIn();
      allow create: if signedIn() && validReservationLockCreate();
      allow update: if signedIn() && (
        isAdmin() ||
        (
          request.auth.uid == resource.data.userId &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.reservationId == resource.data.reservationId &&
          request.resource.data.roomDocId == resource.data.roomDocId &&
          request.resource.data.active == false
        )
      );
      allow delete: if signedIn() && (
        isAdmin() ||
        (
          request.auth.uid == resource.data.userId &&
          getAfter(/databases/$(database)/documents/reservations/$(resource.data.reservationId)).data.status in ['cancelado', 'recusado']
        )
      );
    }

    // Rooms: anyone can read; only admins can create/update/delete
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users: allow users to read/write their own profile document, but prevent them from setting role to admin
    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if signedIn() && (
        (request.auth.uid == userId && (
          (!('role' in request.resource.data) || request.resource.data.role == 'user') ||
          (resource != null && resource.data.role == request.resource.data.role)
        )) ||
        isAdmin()
      );
    }

    // Fallback: deny by default for anything else
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
